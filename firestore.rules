rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissões abertas para o aplicativo funcionar sem erros de Firebase Auth no Android/WebViews
    match /cooking_users/{email} {
      allow read, write: if true;
    }

    match /recipes/{recipeId} {
      allow read, write: if true;
    }

    match /comments/{commentId} {
      allow read, write: if true;
    }

    match /custom_favorites/{favId} {
      allow read, write: if true;
    }
    
    // Legado/compatibilidade
    match /users/{userId} {
      allow read, write: if true;
    }
    match /favorites/{favoriteId} {
      allow read, write: if true;
    }
  }
}
